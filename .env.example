# Salin file ini jadi ".env" lalu isi sesuai kebutuhan
PORT=3000
BASE_URL=http://localhost:3000

# Kunci rahasia untuk session (WAJIB diganti sebelum deploy production)
SESSION_SECRET=ganti-dengan-string-acak-yang-panjang

# Akun admin awal (hanya dipakai saat pertama kali seed database)
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@himatekkom.local
ADMIN_PASSWORD=himatekkom2026

# ---- Login dengan Google (opsional) ----
# Cara dapatkan: https://console.cloud.google.com/apis/credentials
# 1. Buat project baru (atau pakai yang sudah ada)
# 2. Configure OAuth consent screen (External, isi nama app & email)
# 3. Buat "OAuth Client ID" tipe "Web application"
# 4. Authorized redirect URI: http://localhost:3000/api/auth/google/callback
#    (ganti domain kalau sudah deploy ke hosting)
# 5. Copy Client ID & Client Secret ke bawah ini
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# Kalau email Google yang login sama dengan ADMIN_EMAIL di atas,
# akun tersebut otomatis mendapat role admin.
